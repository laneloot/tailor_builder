{
  "id": "dragon-justin",
  "name": "Dragon Justin",
  "description": "Clean black-and-white 1-column layout with ruled section headers for Justin(Dragon)",
  "disabled": false,
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.45in 0.5in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:Arial,Helvetica,sans-serif;font-size:10.5px;line-height:1.4;color:#000}\n    .header{text-align:center;padding-bottom:6px;border-bottom:1px solid #000;margin-bottom:8px}\n    .name{font-size:26px;font-weight:bold;letter-spacing:1px}\n    .title{font-size:13px;font-weight:bold;margin:2px 0 5px}\n    .contact{font-size:10px;display:flex;justify-content:center;flex-wrap:wrap;gap:14px;color:#000}\n    .contact a{color:#000;text-decoration:none}\n    .section{margin-bottom:10px}\n    .section-title{font-size:11px;font-weight:bold;text-transform:uppercase;border-bottom:1px solid #000;padding-bottom:2px;margin-bottom:5px;letter-spacing:0.5px}\n    .summary-text{font-size:10.5px}\n    .skills-text{font-size:10.5px}\n    .exp-header{display:flex;justify-content:space-between;align-items:baseline}\n    .exp-job-title{font-weight:bold;font-size:11px}\n    .exp-date{font-size:10.5px;white-space:nowrap}\n    .exp-company{font-size:10.5px;margin-bottom:3px}\n    .exp-desc{font-size:10.5px;margin-bottom:3px}\n    .exp-bullets{padding-left:16px;font-size:10.5px}\n    .exp-bullets li{margin-bottom:2px}\n    .exp-entry{margin-bottom:9px}\n    .achievement-title{font-weight:bold;font-size:10.5px}\n    .achievement-desc{font-size:10.5px;margin-bottom:5px}\n    .edu-header{display:flex;justify-content:space-between;align-items:baseline}\n    .edu-degree{font-weight:bold;font-size:11px}\n    .edu-date{font-size:10.5px;white-space:nowrap}\n    .edu-institution{font-size:10.5px}\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <div class=\"name\">{{name}}</div>\n    <div class=\"title\">{{title}}</div>\n    <div class=\"contact\">\n      <span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:2px\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1 19.79 19.79 0 0 1 1.64 4.55 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.09 6.09l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z\"/></svg>{{contact.phone}}</span>\n      <span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:2px\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"/><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/></svg>{{contact.email}}</span>\n      {{#if contact.linkedin}}<span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"currentColor\" style=\"vertical-align:middle;margin-right:2px\"><path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\"/><rect width=\"4\" height=\"12\" x=\"2\" y=\"9\"/><circle cx=\"4\" cy=\"4\" r=\"2\"/></svg><a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}\n      <span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:2px\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>{{contact.location}}</span>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div class=\"summary-text\">{{summary}}</div>\n  </div>\n\n  <div class=\"section\">\n    <div class=\"section-title\">Skills</div>\n    <div class=\"skills-text\">{{#if hardSkills.length}}{{#each hardSkills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}{{#each skills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}</div>\n  </div>\n\n  <div class=\"section\">\n    <div class=\"section-title\">Professional Experience</div>\n    {{#each experience}}\n    <div class=\"exp-entry\">\n      <div class=\"exp-header\">\n        <div class=\"exp-job-title\">{{title}}</div>\n        <div class=\"exp-date\">{{startDate}} - {{endDate}}</div>\n      </div>\n      <div class=\"exp-company\">{{company}}{{#if location}} | {{location}}{{/if}}</div>\n      {{#if description}}<div class=\"exp-desc\">{{description}}</div>{{/if}}\n      {{#if achievements}}\n      <ul class=\"exp-bullets\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul>\n      {{/if}}\n    </div>\n    {{/each}}\n  </div>\n\n  {{#if strengths}}\n  <div class=\"section\">\n    <div class=\"section-title\">Key Achievements</div>\n    {{#each strengths}}\n    <div>\n      <div class=\"achievement-title\">{{title}}</div>\n      <div class=\"achievement-desc\">{{description}}</div>\n    </div>\n    {{/each}}\n  </div>\n  {{/if}}\n\n  <div class=\"section\">\n    <div class=\"section-title\">Education</div>\n    {{#each education}}\n    <div>\n      <div class=\"edu-header\">\n        <div class=\"edu-degree\">{{degree}}</div>\n        <div class=\"edu-date\">{{startDate}} - {{endDate}}</div>\n      </div>\n      <div class=\"edu-institution\">{{institution}}{{#if location}} | {{location}}{{/if}}</div>\n    </div>\n    {{/each}}\n  </div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "skills",
    "experience",
    "strengths",
    "education"
  ],
