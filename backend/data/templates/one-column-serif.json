{
  "id": "one-column-serif",
  "name": "Jacky_RyanPham",
  "description": "Classic 1-column with Georgia serif typography",
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.35in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:Georgia,'Times New Roman',serif;font-size: 9px;line-height:1.4;color:#2d2d2d}\n    .header{text-align:center;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid #333}\n    .name{font-size: 23px;font-weight:normal;color:#1a1a1a}\n    .title{font-size: 17px;font-style:italic;color:#555;margin:4px 0}\n    .contact{font-size: 9px;color:#666}\n    .contact a{color:#000;text-decoration:none}\n    .section{margin-bottom:12px}\n    .section-title{font-size: 13px;font-weight:bold;font-variant:small-caps;color:#333;margin-bottom:6px}\n    .job-title{font-weight:bold;font-size: 13px;color:#1a1a1a}\n    .company-line{display:flex;justify-content:space-between;font-size: 9px;font-style:italic;color:#555}\n    .achievements{padding-left:18px;font-size: 9px}\n    .skills-list{font-size: 9px;line-height:1.6}\n    .strength-title{font-weight:bold;font-size: 13px}\n    .strength-description{font-size: 9px;font-style:italic;color:#555}\n    .degree{font-weight:bold;font-size: 13px}\n    .institution{font-size: 9px;font-style:italic}\n    .edu-date{font-size: 9px;color:#666}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\">📞 {{contact.phone}} &nbsp; ✉ {{contact.email}} {{#if contact.linkedin}}&nbsp; 🔗 <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a>{{/if}} &nbsp; 📍 {{contact.location}}</div></div>\n  <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n  {{#if strengths.length}}\n  <div class=\"section\"><div class=\"section-title\">Strengths</div>{{#each strengths}}<div style=\"margin-bottom:6px\"><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Hard Skills</div><div class=\"skills-list\">{{#if hardSkills.length}}{{#each hardSkills}}{{this}}{{#unless @last}} &bull; {{/unless}}{{/each}}{{else}}{{#each skills}}{{this}}{{#unless @last}} &bull; {{/unless}}{{/each}}{{/if}}</div></div>\n  {{#if softSkills.length}}\n  <div class=\"section\"><div class=\"section-title\">Soft Skills</div><div class=\"skills-list\">{{#each softSkills}}{{this}}{{#unless @last}} &bull; {{/unless}}{{/each}}</div></div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Experience</div>\n  {{#each experience}}\n  <div style=\"margin-bottom:10px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n  {{/each}}\n  </div>\n  <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:8px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "strengths",
    "hardSkills",
    "softSkills",
    "experience",
    "education"
  ],
