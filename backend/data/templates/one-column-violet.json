{
  "id": "one-column-violet",
  "name": "One-Column Violet",
  "description": "Elegant 1-column with violet and lavender accents",
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.35in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:'Bookman Old Style',Georgia,serif;font-size: 9px;line-height:1.35;color:#2e1065}\n    .header{text-align:center;padding-bottom:10px;border-bottom:2px solid #7c3aed;margin-bottom:10px}\n    .name{font-size: 23px;font-weight:bold;color:#4c1d95}\n    .title{font-size: 17px;color:#6d28d9;margin:3px 0}\n    .contact{font-size: 9px;display:flex;flex-wrap:wrap;justify-content:center;gap:12px}\n    .contact a{color:#000;text-decoration:none}\n    .section{margin-bottom:9px}\n    .section-title{font-size: 13px;font-weight:bold;color:#5b21b6;text-transform:uppercase;letter-spacing:0.5px;background:#ede9fe;padding:4px 8px;margin-bottom:5px;border-radius:2px}\n    .job-title{font-weight:bold;font-size: 13px;color:#4c1d95}\n    .company-line{display:flex;justify-content:space-between;font-size: 9px;color:#6d28d9}\n    .achievements{padding-left:14px;font-size: 9px}\n    .skills-list{display:flex;flex-wrap:wrap;gap:5px}\n    .skill-chip{background:#f5f3ff;border:1px solid #c4b5fd;padding:2px 7px;font-size: 9px;color:#5b21b6}\n    .strength-title{font-weight:bold;font-size: 13px;color:#4c1d95}\n    .strength-description{font-size: 9px;color:#6d28d9}\n    .degree{font-weight:bold;font-size: 13px}\n    .institution,.edu-date{font-size: 9px;color:#6d28d9}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\"><span>📞 {{contact.phone}}</span><span>✉ {{contact.email}}</span>{{#if contact.linkedin}}<span>🔗 <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span>📍 {{contact.location}}</span></div></div>\n  <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n  {{#if strengths.length}}\n  <div class=\"section\"><div class=\"section-title\">Strengths</div>{{#each strengths}}<div style=\"margin-bottom:5px\"><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Hard Skills</div><div class=\"skills-list\">{{#if hardSkills.length}}{{#each hardSkills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{else}}{{#each skills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{/if}}</div></div>\n  {{#if softSkills.length}}\n  <div class=\"section\"><div class=\"section-title\">Soft Skills</div><div class=\"skills-list\">{{#each softSkills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}</div></div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Experience</div>\n  {{#each experience}}\n  <div style=\"margin-bottom:8px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n  {{/each}}\n  </div>\n  <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:6px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "strengths",
    "hardSkills",
    "softSkills",
    "experience",
    "education"
  ],
