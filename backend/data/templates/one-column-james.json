{
  "id": "one-column-james",
  "name": "One-Column James",
  "description": "Clean 1-column black layout styled after James Johnson resume",
  "disabled": false,
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.35in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:Calibri,'Segoe UI',Arial,sans-serif;font-size:11.5px;line-height:1.4;color:#000000}\n    .header{margin-bottom:8px}\n    .name{font-size:26px;font-weight:bold;color:#000000;line-height:1.1;text-transform:uppercase;text-align:center}\n    .title{font-size:13px;font-weight:600;color:#000000;margin:3px 0 5px 0;text-align:center}\n    .contact{font-size:11px;display:flex;flex-wrap:wrap;gap:12px;color:#000000;justify-content:center}\n    .contact a{color:#000000;text-decoration:none}\n    .divider{border:none;border-top:1.5px solid #000000;margin:6px 0}\n    .section{margin-bottom:8px}\n    .section-title{font-size:12.5px;font-weight:bold;color:#000000;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #000000;padding-bottom:1px;margin-bottom:5px}\n    .job-header{display:flex;justify-content:space-between;align-items:baseline}\n    .job-title{font-weight:bold;font-size:12px;color:#000000}\n    .job-meta{font-size:11px;color:#000000}\n    .job-description{font-size:11.5px;color:#000000;margin:2px 0}\n    .achievements{padding-left:13px;font-size:11.5px;color:#000000}\n    .achievements li{margin-bottom:1px}\n    .skills-text{font-size:11.5px;color:#000000;line-height:1.6}\n    .strength-title{font-weight:bold;font-size:12px;color:#000000;margin-bottom:1px}\n    .strength-description{font-size:11.5px;color:#000000;margin-bottom:5px}\n    .degree{font-weight:bold;font-size:12px;color:#000000}\n    .institution{font-size:11.5px;color:#000000}\n    .edu-date{font-size:11px;color:#000000}\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <div class=\"name\">{{name}}</div>\n    <div class=\"title\">{{title}}</div>\n    <div class=\"contact\"><span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1 19.79 19.79 0 0 1 1.64 4.55 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.09 6.09l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z\"/></svg>{{contact.phone}}</span><span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"/><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/></svg>{{contact.email}}</span>{{#if contact.linkedin}}<span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"currentColor\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\"/><rect width=\"4\" height=\"12\" x=\"2\" y=\"9\"/><circle cx=\"4\" cy=\"4\" r=\"2\"/></svg><a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>{{contact.location}}</span></div>\n  </div>\n  <hr class=\"divider\">\n  <div class=\"section\"><div style=\"font-size:11.5px;color:#000000\">{{summary}}</div></div>\n  <hr class=\"divider\">\n  <div class=\"section\"><div class=\"section-title\">Skills</div><div class=\"skills-text\">{{#if hardSkills.length}}{{#each hardSkills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}{{#each skills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}</div></div>\n  <div class=\"section\"><div class=\"section-title\">Professional Experience</div>\n  {{#each experience}}\n  <div style=\"margin-bottom:8px\"><div class=\"job-header\"><span class=\"job-title\">{{title}}</span><span class=\"job-meta\">{{startDate}} - {{endDate}}</span></div><div class=\"job-meta\" style=\"margin-bottom:2px\">{{company}}{{#if location}} | {{location}}{{/if}}</div><div class=\"job-description\">{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n  {{/each}}\n  </div>\n  {{#if strengths.length}}\n  <div class=\"section\"><div class=\"section-title\">Key Achievements</div>{{#each strengths}}<div><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:5px\"><div class=\"job-header\"><span class=\"degree\">{{degree}}</span><span class=\"edu-date\">{{startDate}} - {{endDate}}</span></div><div class=\"institution\">{{institution}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "hardSkills",
    "experience",
    "strengths",
    "education"
  ],
