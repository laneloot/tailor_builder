  "description": "Professional 1-column with PDF-style clean black theme",
  "disabled": false,
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.35in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:Calibri,'Segoe UI',Arial,sans-serif;font-size:12pt;line-height:1.45;color:#1a1a1a}\n    .header{text-align:center;padding:12px;background:#ffffff;border-bottom:2px solid #1a1a1a;margin-bottom:10px}\n    .name{font-size:24pt;font-weight:bold;color:#1a1a1a}\n    .title{font-size:13pt;font-weight:600;color:#444444;text-transform:uppercase;letter-spacing:1.2px;margin:3px 0}\n    .contact{font-size:10pt;display:flex;flex-wrap:wrap;justify-content:center;gap:12px}\n    .contact a{color:#444444;text-decoration:none}\n    .section{margin-bottom:9px}\n    .section-title{font-size:13pt;font-weight:bold;color:#1a1a1a;text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid #1a1a1a;padding-bottom:2px;margin-bottom:6px}\n    .job-title{font-weight:bold;font-size:12pt;color:#1a1a1a}\n    .company-line{display:flex;justify-content:space-between;font-size:10pt;color:#1a1a1a;font-weight:600}\n    .company-line .date-loc{color:#444444;font-weight:400}\n    .achievements{padding-left:14px;font-size:12pt;color:#1a1a1a}\n    .skills-text{font-size:12pt;color:#1a1a1a;line-height:1.6}\n    .strength-title{font-weight:bold;font-size:12pt;color:#1a1a1a}\n    .strength-description{font-size:12pt;color:#444444}\n    .degree{font-weight:bold;font-size:12pt;color:#1a1a1a}\n    .institution{font-size:10pt;color:#444444;font-weight:600}\n    .edu-date{font-size:10pt;color:#444444}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\"><span>📞 {{contact.phone}}</span><span>✉ {{contact.email}}</span>{{#if contact.linkedin}}<span>🔗 <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span>📍 {{contact.location}}</span></div></div>\n  <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n  {{#if strengths.length}}\n  <div class=\"section\"><div class=\"section-title\">Strengths</div>{{#each strengths}}<div style=\"margin-bottom:5px\"><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Hard Skills</div><div class=\"skills-text\">{{#if hardSkills.length}}{{#each hardSkills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}{{#each skills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}</div></div>\n  {{#if softSkills.length}}\n  <div class=\"section\"><div class=\"section-title\">Soft Skills</div><div class=\"skills-text\">{{#each softSkills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div></div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Experience</div>\n  {{#each experience}}\n  <div style=\"margin-bottom:8px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span class=\"date-loc\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n  {{/each}}\n  </div>\n  <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:6px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "strengths",
    "hardSkills",
    "softSkills",
    "experience",
    "education"
  ],
