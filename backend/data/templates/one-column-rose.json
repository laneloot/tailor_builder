{
  "id": "one-column-rose",
  "name": "One-Column Rose",
  "description": "Warm 1-column layout with rose and blush accents",
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.35in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:Cambria,Cochin,Georgia,serif;font-size: 9px;line-height:1.33;color:#4c0519}\n    .header{padding:10px;background:#fef2f2;border-left:5px solid #e11d48;margin-bottom:10px}\n    .name{font-size: 23px;font-weight:bold;color:#9f1239}\n    .title{font-size: 17px;color:#be123c;margin:2px 0 6px 0}\n    .contact{font-size: 9px;display:flex;flex-wrap:wrap;gap:10px}\n    .contact a{color:#000;text-decoration:none}\n    .section{margin-bottom:9px}\n    .section-title{font-size: 13px;font-weight:bold;color:#881337;text-transform:uppercase;border-bottom:1px solid #fda4af;padding-bottom:3px;margin-bottom:5px}\n    .job-title{font-weight:bold;font-size: 13px;color:#9f1239}\n    .company-line{display:flex;justify-content:space-between;font-size: 9px;color:#be123c}\n    .achievements{padding-left:14px;font-size: 9px}\n    .skills-list{display:flex;flex-wrap:wrap;gap:5px}\n    .skill-chip{background:#fff1f2;border:1px solid #fecdd3;padding:2px 7px;font-size: 9px;color:#9f1239}\n    .strength-title{font-weight:bold;font-size: 13px}\n    .strength-description{font-size: 9px;color:#be123c}\n    .degree{font-weight:bold;font-size: 13px}\n    .institution,.edu-date{font-size: 9px;color:#be123c}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\"><span>📞 {{contact.phone}}</span><span>✉ {{contact.email}}</span>{{#if contact.linkedin}}<span>🔗 <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span>📍 {{contact.location}}</span></div></div>\n  <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n  {{#if strengths.length}}\n  <div class=\"section\"><div class=\"section-title\">Strengths</div>{{#each strengths}}<div style=\"margin-bottom:5px\"><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Hard Skills</div><div class=\"skills-list\">{{#if hardSkills.length}}{{#each hardSkills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{else}}{{#each skills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{/if}}</div></div>\n  {{#if softSkills.length}}\n  <div class=\"section\"><div class=\"section-title\">Soft Skills</div><div class=\"skills-list\">{{#each softSkills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}</div></div>\n  {{/if}}\n  <div class=\"section\"><div class=\"section-title\">Experience</div>\n  {{#each experience}}\n  <div style=\"margin-bottom:8px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n  {{/each}}\n  </div>\n  <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:6px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "strengths",
    "hardSkills",
    "softSkills",
    "experience",
    "education"
  ]
}
