{
  "id": "two-column-minimal",
  "name": "Two-Column Minimal",
  "description": "Ultra-minimal 2-column with generous whitespace",
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.4in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:'Helvetica Neue',Arial,sans-serif;font-size: 10px;line-height:1.5;color:#374151}\n    .header{margin-bottom:16px}\n    .name{font-size: 24px;font-weight:300;color:#111;letter-spacing:0.5px}\n    .title{font-size: 18px;color:#6b7280;margin:4px 0 8px 0}\n    .contact{font-size: 10px;color:#9ca3af}\n    .contact a{color:#000;text-decoration:none}\n    .main-container{display:flex;gap:24px}\n    .left-column{flex:0 0 60%}\n    .right-column{flex:0 0 36%}\n    .section{margin-bottom:14px}\n    .section-title{font-size: 14px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}\n    .job-title{font-weight:600;font-size: 14px;color:#111}\n    .company-line{display:flex;justify-content:space-between;font-size: 10px;color:#9ca3af;margin-bottom:2px}\n    .achievements{padding-left:14px;font-size: 10px;color:#4b5563}\n    .skills-list{font-size: 10px;line-height:1.6;color:#4b5563}\n    .strength-title{font-weight:600;font-size: 14px}\n    .strength-description{font-size: 10px;color:#6b7280}\n    .degree{font-weight:600;font-size: 14px}\n    .institution,.edu-date{font-size: 10px;color:#6b7280}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\">📞 {{contact.phone}} &nbsp; ✉ {{contact.email}} {{#if contact.linkedin}}&nbsp; 🔗 <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a>{{/if}} &nbsp; 📍 {{contact.location}}</div></div>\n  <div class=\"main-container\">\n    <div class=\"left-column\">\n      <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n      <div class=\"section\"><div class=\"section-title\">Experience</div>\n      {{#each experience}}\n      <div style=\"margin-bottom:12px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n      {{/each}}\n      </div>\n    </div>\n    <div class=\"right-column\">\n      {{#if strengths.length}}\n      <div class=\"section\"><div class=\"section-title\">Strengths</div>{{#each strengths}}<div style=\"margin-bottom:8px\"><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n      {{/if}}\n      <div class=\"section\"><div class=\"section-title\">Hard Skills</div><div class=\"skills-list\">{{#if hardSkills.length}}{{#each hardSkills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}{{#each skills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}</div></div>\n      {{#if softSkills.length}}\n      <div class=\"section\"><div class=\"section-title\">Soft Skills</div><div class=\"skills-list\">{{#each softSkills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div></div>\n      {{/if}}\n      <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:8px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n    </div>\n  </div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "experience",
    "strengths",
    "hardSkills",
    "softSkills",
    "education"
  ]
}
