  "id": "m-65300e0d",
  "name": "Test 1",
  "description": "Manually styled template",
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page { margin: 0.3in; }\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: Calibri, 'Segoe UI', Arial, sans-serif;\n      font-size: 9pt;\n      line-height: 1.25;\n      color: #000000;\n      font-weight: normal;\n      margin: 0;\n      padding: 0;\n    }\n    .header {\n      text-align: center;\n      margin-bottom: 8px;\n      border-bottom: 2px solid #1e40af;\n      padding-bottom: 8px;\n    }\n    .name {\n      font-size: 28pt;\n      font-weight: bold;\n      font-family: Georgia, serif;\n      color: #1e40af;\n      margin-bottom: 2px;\n    }\n    .title {\n      font-size: 10pt;\n      font-weight: bold;\n      font-family: Calibri, 'Segoe UI', Arial, sans-serif;\n      color: #1e40af;\n      margin-bottom: 4px;\n    }\n    .contact {\n      font-size: 8pt;\n      font-family: Calibri, 'Segoe UI', Arial, sans-serif;\n      color: #333333;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      flex-wrap: wrap;\n      gap: 8px;\n    }\n    .contact-item { display: flex; align-items: center; gap: 3px; }\n    .contact-icon { color: #1e40af; }\n    .contact a { color: #333333; text-decoration: none; }\n    .main-container { display: flex; gap: 15px; }\n    .left-column { flex: 0 0 62%; }\n    .right-column { flex: 0 0 35%; }\n    .section { margin-bottom: 8px; }\n    .section-title {\n      font-size: 24pt;\n      font-weight: bold;\n      font-family: Calibri, 'Segoe UI', Arial, sans-serif;\n      color: #1e40af;\n      text-transform: uppercase;\n      border-bottom: 1px solid #1e40af;\n      padding-bottom: 2px;\n      margin-bottom: 5px;\n    }\n    .summary { font-size: 9pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #000000; font-weight: normal; line-height: 1.3; text-align: justify; }\n    .experience-item { margin-bottom: 8px; }\n    .job-title { font-weight: bold; font-size: 10pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #1e40af; }\n    .company-line {\n      display: flex;\n      justify-content: space-between;\n      font-size: 9pt;\n      font-family: Calibri, 'Segoe UI', Arial, sans-serif;\n      color: #555;\n      margin-bottom: 2px;\n    }\n    .description { font-size: 9pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #000000; font-weight: normal; margin-bottom: 3px; line-height: 1.3; }\n    .achievements { margin: 0; padding-left: 14px; font-size: 8.5pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #000000; }\n    .achievements li { margin-bottom: 1px; line-height: 1.25; }\n    .strength-item { margin-bottom: 8px; }\n    .strength-header { display: flex; align-items: center; gap: 5px; margin-bottom: 2px; }\n    .strength-icon { color: #f59e0b; font-size: 10pt; }\n    .strength-title { font-weight: bold; font-size: 10pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #1e40af; }\n    .strength-description { font-size: 8pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #555; line-height: 1.3; }\n    .skills-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 4px 8px;\n    }\n    .skill-box {\n      font-size: 8pt;\n      font-family: Calibri, 'Segoe UI', Arial, sans-serif;\n      color: #000000;\n      padding: 2px 0;\n      border-bottom: 1px solid #ddd;\n      text-align: center;\n    }\n    .education-item { margin-bottom: 6px; }\n    .degree { font-weight: bold; font-size: 10pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #1e40af; }\n    .institution { font-size: 8pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #555; }\n    .edu-date { font-size: 8pt; font-family: Calibri, 'Segoe UI', Arial, sans-serif; color: #777; }\n    \n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <div class=\"name\">{{name}}</div>\n    <div class=\"title\">{{title}}</div>\n    <div class=\"contact\">\n      <span class=\"contact-item\"><span class=\"contact-icon\">📞</span> {{contact.phone}}</span>\n      <span class=\"contact-item\"><span class=\"contact-icon\">✉</span> {{contact.email}}</span>\n      {{#if contact.linkedin}}<span class=\"contact-item\"><span class=\"contact-icon\">🔗</span> <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}\n      <span class=\"contact-item\"><span class=\"contact-icon\">📍</span> {{contact.location}}</span>\n    </div>\n  </div>\n<div class=\"main-content\">\n      <div class=\"section\" data-section=\"summary\">\n        <div class=\"section-title\">Summary</div>\n        <div class=\"summary\">{{summary}}</div>\n      </div>\n\n      <div class=\"section\" data-section=\"experience\">\n        <div class=\"section-title\">Experience</div>\n        {{#each experience}}\n        <div class=\"experience-item\">\n          <div class=\"job-title\">{{title}}</div>\n          <div class=\"company-line\">\n            <span>{{company}}</span>\n            <span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span>\n          </div>\n          <div class=\"description\">{{description}}</div>\n          <ul class=\"achievements\">\n            {{#each achievements}}\n            <li>{{this}}</li>\n            {{/each}}\n          </ul>\n        </div>\n        {{/each}}\n      </div>\n\n      {{#if strengths.length}}\n      <div class=\"section\" data-section=\"strengths\">\n        <div class=\"section-title\">Strengths</div>\n        {{#each strengths}}\n        <div class=\"strength-item\">\n          <div class=\"strength-header\">\n            <span class=\"strength-icon\">★</span>\n            <span class=\"strength-title\">{{title}}</span>\n          </div>\n          <div class=\"strength-description\">{{description}}</div>\n        </div>\n        {{/each}}\n      </div>\n      {{/if}}\n\n      <div class=\"section\" data-section=\"hardSkills\">\n        <div class=\"section-title\">Hard Skills</div>\n        <div class=\"skills-grid\">\n          {{#if hardSkills.length}}\n          {{#each hardSkills}}\n          <div class=\"skill-box\">{{this}}</div>\n          {{/each}}\n          {{else}}\n          {{#each skills}}\n          <div class=\"skill-box\">{{this}}</div>\n          {{/each}}\n          {{/if}}\n        </div>\n      </div>\n\n      {{#if softSkills.length}}\n      <div class=\"section\" data-section=\"softSkills\">\n        <div class=\"section-title\">Soft Skills</div>\n        <div class=\"skills-grid\">\n          {{#each softSkills}}\n          <div class=\"skill-box\">{{this}}</div>\n          {{/each}}\n        </div>\n      </div>\n      {{/if}}\n\n      <div class=\"section\" data-section=\"education\">\n        <div class=\"section-title\">Education</div>\n        {{#each education}}\n        <div class=\"education-item\">\n          <div class=\"degree\">{{degree}}</div>\n          <div class=\"institution\">{{institution}}</div>\n          <div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div>\n        </div>\n        {{/each}}\n      </div></div>\n</body>\n</html>",
