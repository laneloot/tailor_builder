{
  "id": "two-column-john",
  "name": "Two-Column For John",
  "description": "2-column layout with teal and cyan accents",
  "disabled": false,
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.3in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:Calibri,'Segoe UI',Arial,sans-serif;font-size:13px;line-height:1.4;color:#0a0a0a}\n    .header{padding:10px 0 10px 0;margin-bottom:12px;border-bottom:1px solid #e0e0e0}\n    .name{font-size:28px;font-weight:bold;color:#000000;line-height:1.1;text-align:center}\n    .title{font-size:15.5px;color:#0a7c72;font-weight:600;margin:3px 0 6px 0;text-align:center}\n    .contact{font-size:13px;display:flex;flex-wrap:wrap;gap:14px;color:#222222;justify-content:center}\n    .contact a{color:#222222;text-decoration:none}\n    .main-container{display:flex;gap:0}\n    .left-column{flex:0 0 60%;padding-right:16px}\n    .right-column{flex:0 0 40%;padding-left:14px;border-left:4px solid #0a7c72}\n    .section{margin-bottom:10px}\n    .section-title{font-size:15px;font-weight:bold;color:#000000;text-transform:uppercase;letter-spacing:0.5px;border-bottom:2px solid #0a7c72;padding-bottom:2px;margin-bottom:6px}\n    .job-title{font-weight:bold;font-size:15px;color:#000000}\n    .company-line{display:flex;justify-content:space-between;font-size:13px;margin-bottom:2px}\n    .company-name{color:#0a7c72;font-weight:600}\n    .date-loc{color:#444444;font-size:12px}\n    .job-description{font-size:12.5px;color:#111111;margin-bottom:3px}\n    .achievements{padding-left:13px;font-size:12.5px;color:#111111}\n    .achievements li{margin-bottom:1.5px}\n    .skills-text{font-size:13px;color:#0a0a0a;line-height:1.6}\n    .strength-title{font-weight:bold;font-size:13px;color:#000000;margin-bottom:2px}\n    .strength-description{font-size:12.5px;color:#222222;margin-bottom:6px}\n    .degree{font-weight:bold;font-size:13px;color:#000000}\n    .institution{font-size:12.5px;color:#222222}\n    .edu-date{font-size:12px;color:#444444}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\"><span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1 19.79 19.79 0 0 1 1.64 4.55 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.09 6.09l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z\"/></svg>{{contact.phone}}</span><span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"/><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/></svg>{{contact.email}}</span>{{#if contact.linkedin}}<span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"currentColor\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\"/><rect width=\"4\" height=\"12\" x=\"2\" y=\"9\"/><circle cx=\"4\" cy=\"4\" r=\"2\"/></svg><a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>{{contact.location}}</span></div></div>\n  <div class=\"main-container\">\n    <div class=\"left-column\">\n      <div class=\"section\"><div class=\"section-title\">Experience</div>\n      {{#each experience}}\n      <div style=\"margin-bottom:9px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span class=\"company-name\">{{company}}</span><span class=\"date-loc\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div class=\"job-description\">{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n      {{/each}}\n      </div>\n    </div>\n    <div class=\"right-column\">\n      <div class=\"section\"><div class=\"section-title\">Summary</div><div style=\"font-size:12.5px;color:#111111\">{{summary}}</div></div>\n      <div class=\"section\"><div class=\"section-title\">Skills</div><div class=\"skills-text\">{{#if hardSkills.length}}{{#each hardSkills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}{{#each skills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}</div></div>\n     {{#if strengths.length}}\n      <div class=\"section\"><div class=\"section-title\">Key Achievements</div>{{#each strengths}}<div><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n      {{/if}}\n      <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:7px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n    </div>\n  </div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "experience",
    "strengths",
    "hardSkills",
    "softSkills",
    "education"
  ],
