{
  "id": "one-column-just",
  "name": "One-Column Just",
  "description": "Warm 1-column layout for Justin Young",
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.35in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:'Trebuchet MS',Arial,sans-serif;font-size:12px;line-height:1.35;color:#000000}\n    .header{padding:10px 12px;background:#e8eaf6;border:1px solid #90caf9;border-radius:4px;margin-bottom:10px}\n    .name{font-size:30px;font-weight:bold;color:#1a237e}\n    .title{font-size:22px;color:#1565c0;margin:2px 0 6px 0}\n    .contact{font-size:12px;display:flex;flex-wrap:wrap;gap:10px}\n    .contact a{color:#000;text-decoration:none}\n    .section{margin-bottom:9px}\n    .section-title{font-size:17px;font-weight:bold;color:#1a237e;text-transform:uppercase;border-bottom:2px solid #1976d2;padding-bottom:2px}\n    .job-title{font-weight:bold;font-size:17px;color:#1a237e}\n    .company-line{display:flex;justify-content:space-between;font-size:12px;color:#1565c0}\n    .achievements{padding-left:14px;font-size:12px;color:#000000}\n    .skills-list{display:flex;flex-wrap:wrap;gap:5px}\n    .skill-chip{background:#e3f2fd;border:1px solid #90caf9;padding:2px 7px;font-size:12px;color:#000000}\n    .strength-title{font-weight:bold;font-size:17px;color:#1a237e}\n    .strength-description{font-size:12px;color:#000000}\n    .degree{font-weight:bold;font-size:17px;color:#1a237e}\n    .institution,.edu-date{font-size:12px;color:#000000}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\"><span>📞 {{contact.phone}}</span><span>✉ {{contact.email}}</span>{{#if contact.linkedin}}<span>🔗 <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span>📍 {{contact.location}}</span></div></div>\n  <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n  <div class=\"section\"><div class=\"section-title\">Skills</div><div class=\"skills-list\">{{#if hardSkills.length}}{{#each hardSkills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{else}}{{#each skills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{/if}}</div></div>\n <div class=\"section\"><div class=\"section-title\">Experience</div>\n  {{#each experience}}\n  <div style=\"margin-bottom:8px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n  {{/each}}\n  </div>\n  <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:6px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n </body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "skills",
    "experience",
    "education"
  ],
