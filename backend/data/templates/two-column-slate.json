{
  "id": "two-column-slate",
  "name": "Two column slate",
  "description": "Professional 2-column layout with slate gray theme",
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.3in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:Arial,Helvetica,sans-serif;font-size: 10px;line-height:1.28;color:#334155}\n    .header{text-align:center;margin-bottom:9px;padding-bottom:8px;border-bottom:2px solid #475569}\n    .name{font-size: 24px;font-weight:bold;color:#0f172a}\n    .title{font-size: 18px;color:#475569}\n    .contact{font-size: 10px;display:flex;flex-wrap:wrap;justify-content:center;gap:10px}\n    .contact a{color:#000;text-decoration:none}\n    .main-container{display:flex;gap:15px}\n    .left-column{flex:0 0 62%}\n    .right-column{flex:0 0 35%}\n    .section{margin-bottom:8px}\n    .section-title{font-size: 14px;font-weight:bold;color:#334155;text-transform:uppercase;background:#f8fafc;padding:3px 6px;border-left:3px solid #64748b}\n    .job-title{font-weight:bold;font-size: 14px;color:#0f172a}\n    .company-line{display:flex;justify-content:space-between;font-size: 10px;color:#64748b}\n    .achievements{padding-left:14px;font-size: 10px}\n    .skills-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px 8px}\n    .skill-box{font-size: 10px;padding:2px 5px;border-bottom:1px dotted #94a3b8}\n    .strength-title{font-weight:bold;font-size: 14px}\n    .strength-description{font-size: 10px;color:#64748b}\n    .degree{font-weight:bold;font-size: 14px}\n    .institution,.edu-date{font-size: 10px;color:#64748b}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\"><span>📞 {{contact.phone}}</span><span>✉ {{contact.email}}</span>{{#if contact.linkedin}}<span>🔗 <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span>📍 {{contact.location}}</span></div></div>\n  <div class=\"main-container\">\n    <div class=\"left-column\">\n      <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n      <div class=\"section\"><div class=\"section-title\">Experience</div>\n      {{#each experience}}\n      <div style=\"margin-bottom:8px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n      {{/each}}\n      </div>\n    </div>\n    <div class=\"right-column\">\n      {{#if strengths.length}}\n      <div class=\"section\"><div class=\"section-title\">Strengths</div>{{#each strengths}}<div style=\"margin-bottom:6px\"><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n      {{/if}}\n      <div class=\"section\"><div class=\"section-title\">Hard Skills</div><div class=\"skills-grid\">{{#if hardSkills.length}}{{#each hardSkills}}<div class=\"skill-box\">{{this}}</div>{{/each}}{{else}}{{#each skills}}<div class=\"skill-box\">{{this}}</div>{{/each}}{{/if}}</div></div>\n      {{#if softSkills.length}}\n      <div class=\"section\"><div class=\"section-title\">Soft Skills</div><div class=\"skills-grid\">{{#each softSkills}}<div class=\"skill-box\">{{this}}</div>{{/each}}</div></div>\n      {{/if}}\n      <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:6px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}</div>\n    </div>\n  </div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "experience",
    "strengths",
    "hardSkills",
    "softSkills",
    "education"
  ],
