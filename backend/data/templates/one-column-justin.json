{
  "id": "one-column-justin",
  "name": "One-Column Justin",
  "description": "Warm 1-column layout for Justin Young",
  "disabled": false,
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.35in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:'Trebuchet MS',Arial,sans-serif;font-size:12px;line-height:1.35;color:#000000}\n    .header{padding:10px 12px;background:#e8eaf6;border:1px solid #90caf9;border-radius:4px;margin-bottom:10px}\n    .name{font-size:30px;font-weight:bold;color:#1a237e;text-align:center}\n    .title{font-size:22px;color:#1565c0;margin:2px 0 6px 0;text-align:center}\n    .contact{font-size:12px;display:flex;flex-wrap:wrap;gap:10px}\n    .contact a{color:#000;text-decoration:none}\n    .section{margin-bottom:9px}\n    .section-title{font-size:17px;font-weight:bold;color:#1a237e;text-transform:uppercase;border-bottom:2px solid #1976d2;padding-bottom:2px}\n    .job-title{font-weight:bold;font-size:17px;color:#1a237e}\n    .company-line{display:flex;justify-content:space-between;font-size:12px;color:#1565c0}\n    .achievements{padding-left:14px;font-size:12px;color:#000000}\n    .skills-list{display:flex;flex-wrap:wrap;gap:5px}\n    .skill-chip{background:#e3f2fd;border:1px solid #90caf9;padding:2px 7px;font-size:12px;color:#000000}\n    .strength-title{font-weight:bold;font-size:17px;color:#1a237e}\n    .strength-description{font-size:12px;color:#000000}\n    .degree{font-weight:bold;font-size:17px;color:#1a237e}\n    .institution{font-size:12px;color:#000000}.edu-date{font-size:12px;color:#1565c0;text-align:right}\n  </style>\n</head>\n<body>\n  <div class=\"header\"><div class=\"name\">{{name}}</div><div class=\"title\">{{title}}</div><div class=\"contact\"><span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1 19.79 19.79 0 0 1 1.64 4.55 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.09 6.09l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z\"/></svg>{{contact.phone}}</span><span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"/><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/></svg>{{contact.email}}</span>{{#if contact.linkedin}}<span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"currentColor\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\"/><rect width=\"4\" height=\"12\" x=\"2\" y=\"9\"/><circle cx=\"4\" cy=\"4\" r=\"2\"/></svg><a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"vertical-align:middle;margin-right:3px\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"/><circle cx=\"12\" cy=\"10\" r=\"3\"/></svg>{{contact.location}}</span></div></div>\n  <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n  <div class=\"section\"><div class=\"section-title\">Skills</div><div class=\"skills-list\">{{#if hardSkills.length}}{{#each hardSkills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{else}}{{#each skills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{/if}}</div></div>\n <div class=\"section\"><div class=\"section-title\">Experience</div>\n  {{#each experience}}\n  <div style=\"margin-bottom:8px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n  {{/each}}\n  </div>\n  <div class=\"section\"><div class=\"section-title\">Education</div>{{#each education}}<div style=\"margin-bottom:6px\"><div style=\"display:flex;justify-content:space-between;align-items:baseline\"><div><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div></div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div></div>{{/each}}</div>\n </body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "skills",
    "experience",
    "education"
  ],
  "createdAt": "2026-03-02T00:15:54.533Z",
  "updatedAt": "2026-03-02T00:16:24.632Z"
}