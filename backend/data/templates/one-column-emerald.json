{
  "id": "one-column-emerald",
  "name": "One-Column Emerald",
  "description": "Clean 1-column layout with emerald green accents",
  "htmlContent": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    @page{margin:0.35in}\n    *{margin:0;padding:0;box-sizing:border-box}\n    body{font-family:'Segoe UI',Arial,sans-serif;font-size: 9px;line-height:1.35;color:#14532d}\n    .header{padding:10px 12px;background:linear-gradient(135deg,#d1fae5 0%,#a7f3d0 100%);border-radius:4px;margin-bottom:10px}\n    .name{font-size: 23px;font-weight:bold;color:#064e3b}\n    .title{font-size: 17px;color:#047857;margin:2px 0 6px 0}\n    .contact{font-size: 9px;display:flex;flex-wrap:wrap;gap:10px}\n    .contact a{color:#000;text-decoration:none}\n    .section{margin-bottom:10px}\n    .section-title{font-size: 13px;font-weight:bold;color:#065f46;text-transform:uppercase;border-bottom:2px solid #10b981;padding-bottom:2px;margin-bottom:5px}\n    .job-title{font-weight:bold;font-size: 13px;color:#064e3b}\n    .company-line{display:flex;justify-content:space-between;font-size: 9px;color:#047857}\n    .achievements{padding-left:14px;font-size: 9px}\n    .skills-list{display:flex;flex-wrap:wrap;gap:6px}\n    .skill-chip{background:#d1fae5;color:#065f46;padding:3px 8px;border-radius:12px;font-size: 9px;border:1px solid #a7f3d0}\n    .strength-title{font-weight:bold;font-size: 13px}\n    .strength-description{font-size: 9px;color:#047857}\n    .degree{font-weight:bold;font-size: 13px}\n    .institution,.edu-date{font-size: 9px;color:#047857}\n  </style>\n</head>\n<body>\n  <div class=\"header\">\n    <div class=\"name\">{{name}}</div>\n    <div class=\"title\">{{title}}</div>\n    <div class=\"contact\"><span>📞 {{contact.phone}}</span><span>✉ {{contact.email}}</span>{{#if contact.linkedin}}<span>🔗 <a href=\"{{contact.linkedin}}\">{{contact.linkedin}}</a></span>{{/if}}<span>📍 {{contact.location}}</span></div>\n  </div>\n  <div class=\"section\"><div class=\"section-title\">Summary</div><div>{{summary}}</div></div>\n  {{#if strengths.length}}\n  <div class=\"section\"><div class=\"section-title\">Strengths</div>{{#each strengths}}<div style=\"margin-bottom:5px\"><div class=\"strength-title\">{{title}}</div><div class=\"strength-description\">{{description}}</div></div>{{/each}}</div>\n  {{/if}}\n  <div class=\"section\">\n    <div class=\"section-title\">Hard Skills</div>\n    <div class=\"skills-list\">{{#if hardSkills.length}}{{#each hardSkills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{else}}{{#each skills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}{{/if}}</div>\n  </div>\n  {{#if softSkills.length}}\n  <div class=\"section\"><div class=\"section-title\">Soft Skills</div><div class=\"skills-list\">{{#each softSkills}}<span class=\"skill-chip\">{{this}}</span>{{/each}}</div></div>\n  {{/if}}\n  <div class=\"section\">\n    <div class=\"section-title\">Experience</div>\n    {{#each experience}}\n    <div style=\"margin-bottom:8px\"><div class=\"job-title\">{{title}}</div><div class=\"company-line\"><span>{{company}}</span><span>{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</span></div><div>{{description}}</div><ul class=\"achievements\">{{#each achievements}}<li>{{this}}</li>{{/each}}</ul></div>\n    {{/each}}\n  </div>\n  <div class=\"section\"><div class=\"section-title\">Education</div>\n  {{#each education}}<div style=\"margin-bottom:6px\"><div class=\"degree\">{{degree}}</div><div class=\"institution\">{{institution}}</div><div class=\"edu-date\">{{startDate}} - {{endDate}}{{#if location}} | {{location}}{{/if}}</div></div>{{/each}}\n  </div>\n</body>\n</html>",
  "cssContent": "",
  "sections": [
    "summary",
    "strengths",
    "hardSkills",
    "softSkills",
    "experience",
    "education"
  ],
  "disabled": false,
  "updatedAt": "2026-02-21T14:02:00.666Z"
}
