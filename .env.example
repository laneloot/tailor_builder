HOST=0.0.0.0
PORT=3001

# Comma-separated frontend origins allowed by the backend CORS config.
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000

# Frontend API base settings.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_FALLBACK_API_URL=

# Optional admin/token settings.
ADMIN_PASSWORD=change-me
ADMIN_TOKEN_SECRET=change-me

# AI provider keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://localhost:3001
OPENROUTER_APP_NAME=Tailored Resume Builder

# Google Sheets service account JSON path.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
